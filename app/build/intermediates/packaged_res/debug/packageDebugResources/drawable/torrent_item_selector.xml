<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state (D-pad navigation on TV) -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#443D5AFE" />
            <stroke android:width="2dp" android:color="#7C4DFF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#663D5AFE" />
            <stroke android:width="2dp" android:color="#B388FF" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#222236" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
