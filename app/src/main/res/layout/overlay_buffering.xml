<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/buffering_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:visibility="gone"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="500dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/torrent_item_selector"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/buffering_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connecting_p2p"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Torrent name -->
        <TextView
            android:id="@+id/buffering_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Movie Name"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="20dp" />

        <!-- Progress Bar -->
        <com.epicgera.vtrae.ui.components.AetherLoadingView
            android:id="@+id/buffering_progress"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:layout_marginBottom="12dp" />

        <!-- Percentage + Peers row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/buffering_percent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0%"
                android:textColor="#4CAF50"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/buffering_peers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐 0 peers"
                android:textColor="#90CAF9"
                android:textSize="16sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Download speed -->
        <TextView
            android:id="@+id/buffering_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />

    </LinearLayout>

</FrameLayout>

